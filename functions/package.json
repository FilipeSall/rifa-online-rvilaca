{
  "name": "rifa-online-functions",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "rm -rf lib && tsc -p tsconfig.json",
    "test": "bun run build && node --test \"lib/**/*.test.js\"",
    "migrate:number-chunks": "node scripts/migrate-number-states-to-chunks.mjs",
