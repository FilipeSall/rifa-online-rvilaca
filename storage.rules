rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Avatares de usuário: leitura pública, escrita apenas pelo próprio usuário.
    // Restringe tamanho máximo (5MB) e tipo de conteúdo (imagem).
    match /users/{userId}/avatar {
      allow read: if true;
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Midias da campanha (carrossel da home): leitura pública e gerenciamento por admin.
    match /campaigns/{campaignId}/hero/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    // Video de destaque da campanha: leitura pública e gerenciamento por admin.
    match /campaigns/{campaignId}/featured-video/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 70 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
      allow delete: if isAdmin();
    }

    // Negar todo o resto por padrão.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
