VITE_FIREBASE_API_KEY=your-api-key
# IMPORTANTE: Em producao com dominio customizado, use o seu dominio (ex: jhonnybarber.com.br)
# em vez de your-project.firebaseapp.com. Isso faz o auth domain ser first-party,
# necessario para signInWithRedirect funcionar no Safari iOS 16+ (ITP bloqueia third-party cookies).
# Firebase Hosting serve automaticamente /__/auth/ em dominios customizados.
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_FIREBASE_FUNCTIONS_REGION=southamerica-east1
# Defina em arquivos por ambiente:
# - .env.development => authDomain firebaseapp.com + popup
# - .env.production  => authDomain customizado + redirect
VITE_FIREBASE_GOOGLE_AUTH_FLOW=auto
VITE_FIREBASE_APPCHECK_SITE_KEY=your-recaptcha-v3-site-key
VITE_FIREBASE_APPCHECK_ENABLED=false
VITE_FIREBASE_APPCHECK_PROVIDER=v3

# Firestore seed script (server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
SEED_CAMPAIGN_ID=campanha-bmw-r1200-gs-2026
SEED_PRECREATE_NUMBERS=0
ALLOW_LARGE_NUMBER_SEED=false
SEED_CREATE_EXAMPLES=false
