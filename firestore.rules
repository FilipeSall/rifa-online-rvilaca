rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Dados públicos de campanha usados pela landing page.
    match /campaigns/{campaignId} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    // Sorteios e ganhadores — visibilidade pública.
    match /draws/{drawId} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    match /winners/{winnerId} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    // Modelo por chunks para disponibilidade (server-only).
    match /numberChunks/{chunkId} {
      allow read, write: if false;
    }

    // Reserva ativa por usuário: leitura somente do dono, escrita apenas via backend.
    match /numberReservations/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Perfil do usuário: leitura apenas do próprio usuário.
    // Escrita é server-only via Cloud Functions (Admin SDK) para manter
    // consistência entre users, cpfRegistry e phoneRegistry.
    match /users/{uid} {
      allow get: if isOwner(uid);
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Registro de CPF para prevenir contas duplicadas.
    // Imutável após criação: update e delete são negados.
    match /cpfRegistry/{cpfId} {
      allow create: if isSignedIn()
        && cpfId.matches('^[0-9]{11}$')
        && request.resource.data.keys().hasOnly(['uid', 'cpf', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.cpf == cpfId;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if false;
      allow update, delete: if false;
    }

    match /phoneRegistry/{phoneId} {
      allow create: if isSignedIn()
        && phoneId.matches('^[0-9]{10,11}$')
        && request.resource.data.keys().hasOnly(['uid', 'phone', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phone == phoneId;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if false;
      allow update, delete: if false;
    }

    // Coleções sensíveis/transacionais — somente backend via Admin SDK.
    match /orders/{orderId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read, write: if false;
    }

    // Negar tudo que não foi explicitamente permitido acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
